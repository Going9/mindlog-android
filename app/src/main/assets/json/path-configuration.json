{
    "settings": {},
    "rules": [
        {
            "patterns": [
                ".*"
            ],
            "properties": {
                "context": "default",
                "uri": "hotwire://fragment/web",
                "animated": false,
                "pull_to_refresh_enabled": true
            }
        },
        {
            "patterns": [
                "^/diaries$",
                "^/insights/emotions$"
            ],
            "properties": {
                "context": "default",
                "uri": "hotwire://fragment/web",
                "presentation": "replace",
                "animated": false,
                "pull_to_refresh_enabled": false
            }
        },
        {
            "patterns": [
                "/auth/login/.*"
            ],
            "properties": {
                "context": "default",
                "uri": "hotwire://fragment/web",
                "animated": false,
                "open_external": true
            }
        }
    ]
}
