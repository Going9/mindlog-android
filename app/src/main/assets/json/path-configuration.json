{
  "settings": {},
  "rules": [
    {
      "patterns": [
        ".*"
      ],
      "properties": {
        "context": "default",
        "uri": "hotwire://fragment/web",
        "pull_to_refresh_enabled": true,
        "animated": false
      }
    },
    {
      "patterns": [
        "/diaries/new$",
        "/diaries/\\d+$",
        "/diaries/\\d+/edit$"
      ],
      "properties": {
        "context": "default",
        "uri": "hotwire://fragment/web",
        "animated": false
      }
    },
    {
      "patterns": [
        "/auth/login.*"
      ],
      "properties": {
        "context": "default",
        "uri": "hotwire://fragment/web",
        "open_external": true
      }
    }
  ]
}
