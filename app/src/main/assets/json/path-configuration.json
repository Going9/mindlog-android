{
    "settings": {},
    "rules": [
        {
            "patterns": [
                ".*"
            ],
            "properties": {
                "context": "default",
                "uri": "hotwire://fragment/web",
                "pull_to_refresh_enabled": true
            }
        },
        {
            "patterns": [
                "/auth/login/.*"
            ],
            "properties": {
                "context": "default",
                "uri": "hotwire://fragment/web",
                "open_external": true
            }
        }
    ]
}
